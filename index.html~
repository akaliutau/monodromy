  <script>
    (function () {
      const logoMark = document.getElementById('brandMark');
      const logoImg = logoMark.querySelector('.logo-img');

      if (logoImg.complete && logoImg.naturalWidth > 0) {
        logoMark.classList.add('loaded');
      } else {
        logoImg.addEventListener('load', () => logoMark.classList.add('loaded'));
      }

      const canvas = document.getElementById('stars');
      const ctx = canvas.getContext('2d');
      const stars = [];
      const colors = ['#4a84ff', '#6d63ff', '#f2c94c'];
      const maxStars = 68;
      let w = 0;
      let h = 0;
      let dpr = Math.max(1, Math.min(2, window.devicePixelRatio || 1));

      function resize() {
        w = window.innerWidth;
        h = window.innerHeight;
        dpr = Math.max(1, Math.min(2, window.devicePixelRatio || 1));
        canvas.width = Math.floor(w * dpr);
        canvas.height = Math.floor(h * dpr);
        canvas.style.width = w + 'px';
        canvas.style.height = h + 'px';
        ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
        buildStars();
      }

      function buildStars() {
        stars.length = 0;
        const count = Math.max(36, Math.floor((w * h) / 22000));
        const finalCount = Math.min(maxStars, count);
        for (let i = 0; i < finalCount; i++) {
          stars.push({
            x: Math.random() * w,
            y: Math.random() * h,
            r: Math.random() * 1.9 + 0.7,
            dx: (Math.random() - 0.5) * 0.09,
            dy: (Math.random() - 0.5) * 0.09,
            a: Math.random() * 0.5 + 0.18,
            pulse: Math.random() * Math.PI * 2,
            color: colors[i % colors.length]
          });
        }
      }

      function draw() {
        ctx.clearRect(0, 0, w, h);
        for (const s of stars) {
          s.x += s.dx;
          s.y += s.dy;
          s.pulse += 0.014;

          if (s.x < -10) s.x = w + 10;
          if (s.x > w + 10) s.x = -10;
          if (s.y < -10) s.y = h + 10;
          if (s.y > h + 10) s.y = -10;

          const alpha = s.a + Math.sin(s.pulse) * 0.08;
          ctx.beginPath();
          ctx.fillStyle = hexToRgba(s.color, Math.max(0.08, alpha));
          ctx.shadowBlur = 18;
          ctx.shadowColor = hexToRgba(s.color, 0.35);
          ctx.arc(s.x, s.y, s.r, 0, Math.PI * 2);
          ctx.fill();
          ctx.shadowBlur = 0;
        }
        requestAnimationFrame(draw);
      }

      function hexToRgba(hex, alpha) {
        const clean = hex.replace('#', '');
        const bigint = parseInt(clean, 16);
        const r = (bigint >> 16) & 255;
        const g = (bigint >> 8) & 255;
        const b = bigint & 255;
        return 'rgba(' + r + ',' + g + ',' + b + ',' + alpha + ')';
      }

      resize();
      draw();
      window.addEventListener('resize', resize);
    })();
  </script>
